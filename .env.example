# Database
DB_HOST=localhost
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=comm-db
DB_PORT=5432

# RabbitMQ
RABBITMQ_URL=amqp://user:password@localhost

# App
APP_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# SMS Provider
SMS_PROVIDER=ooredoo
SMS_PROVIDER_URL=https://api.ooredoo.example.com/sms
SMS_PROVIDER_KEY=your-sms-provider-key
SMS_FROM_NUMBER=AxeDz

# SMTP for Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@axedz.com
SMTP_SECURE=false

# Auth Service
AUTH_SERVICE_URL=http://localhost:3002

# Costs
SMS_COST=0.05
EMAIL_COST=0.01

# API Keys (for seeding)
API_KEY_1=your-api-key-1
API_KEY_2=your-api-key-2